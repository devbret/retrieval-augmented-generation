[Unit]
Description=Personal Knowledge RAG server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/retrieval-augmented-generation
ExecStart=/home/YOUR_USER/retrieval-augmented-generation/venv/bin/uvicorn rag_server:app --host 0.0.0.0 --port 47821
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
